# Vercel Cronからの不正アクセス防止
CRON_SECRET=replace-with-long-random-string

# noteの編集画面URL（例: https://editor.note.com/notes/xxxxxxxx/edit ）
NOTE_EDITOR_URL=https://editor.note.com/notes/xxxxxxxxxxxxxxxx/edit

# 投稿する記事タイトル
NOTE_ARTICLE_TITLE=定期投稿タイトル

# 投稿する本文（改行可）
NOTE_ARTICLE_BODY=1段落目\n\n2段落目

# trueで公開、falseで下書き確認のみ
NOTE_PUBLISH=false

# note.comへログイン済みCookie配列(JSON文字列)
# 例: [{"name":"sess","value":"...","domain":".note.com","path":"/","httpOnly":true,"secure":true,"sameSite":"Lax"}]
NOTE_AUTH_COOKIES=[]

# ローカル開発時のChromium/Chrome実行ファイルパス
# macOS例: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux例: /usr/bin/google-chrome
# Windows例: C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
PLAYWRIGHT_EXECUTABLE_PATH=

# ローカルデバッグ用。ブラウザ表示を見たい場合は false
NOTE_HEADLESS=true

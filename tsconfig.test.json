{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["lib/api-query.ts", "lib/timetable-core.ts", "lib/timetable-dto.ts", "tests/**/*.test.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
